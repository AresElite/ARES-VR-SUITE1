# A.R.E.S. VR Performance Suite — environment template
# Copy to .env.local for local overrides. All values optional for the MVP.

# Future EMR sync endpoint (placeholder — the API layer no-ops without it)
VITE_EMR_API_URL=
VITE_EMR_API_KEY=

# Force a performance mode: quest2-safe | quest3s-balanced | quest3-enhanced
VITE_FORCE_PERF_MODE=

# Enable verbose drill-engine logging in the console
VITE_DEBUG_DRILLS=false
